{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(tree:*)",
      "Bash(find:*)",
      "Bash(curl:*)",
      "Bash(mkdir:*)",
      "Bash(echo:*)",
      "Bash(sleep:*)",
      "Bash(kill:*)",
      "Bash(wait:*)",
      "Bash(npx nx:*)",
      "Bash(npx tsc --project apps:*)",
      "Bash(git log *)",
      "Read",
      "WebFetch",
      "Agent"
    ],
    "deny": ["Bash(git commit *)"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-project-dir.sh"
          }
        ]
      }
    ]
  }
}
