{
  "name": "api-gateway",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api-gateway/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/api-gateway",
        "main": "apps/api-gateway/src/main.ts",
        "tsConfig": "apps/api-gateway/tsconfig.app.json",
        "assets": ["apps/api-gateway/src/assets"]
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "api-gateway:build",
        "runBuildTargetDependencies": false,
        "runtimeArgs": ["--require", "./dist/libs/telemetry/src/init-telemetry.js"],
        "watch": true
      },
      "configurations": {
        "development": {
          "buildTarget": "api-gateway:build"
        },
        "production": {
          "buildTarget": "api-gateway:build"
        }
      }
    }
  },
  "tags": [],
  "implicitDependencies": ["ee-gateway"]
}
