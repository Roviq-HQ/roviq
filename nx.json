{
  "$schema": "https://nx.dev/reference/nx-json",
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "test": {
      "cache": true,
      "inputs": ["default", "^production"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "biome check {projectRoot}"
      },
      "cache": true
    },
    "typecheck": {
      "cache": true
    },
    "@nx/js:tsc": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    }
  },
  "defaultBase": "main",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": ["{workspaceRoot}/tsconfig.base.json", "{workspaceRoot}/biome.json"],
    "production": ["default", "!{projectRoot}/**/*.spec.ts", "!{projectRoot}/**/*.test.ts"]
  },
  "plugins": [
    {
      "plugin": "@nx/vitest",
      "exclude": ["e2e/**"],
      "options": {
        "testTargetName": "test",
        "testMode": "run"
      }
    },
    {
      "plugin": "@nx/vitest",
      "include": ["e2e/**"],
      "options": {
        "testTargetName": "e2e",
        "testMode": "run"
      }
    },
    {
      "plugin": "@nx/playwright",
      "options": {
        "targetName": "e2e"
      }
    },
    {
      "plugin": "@nx/next/plugin",
      "options": {
        "startTargetName": "start",
        "buildTargetName": "build",
        "devTargetName": "dev",
        "serveStaticTargetName": "serve-static",
        "buildDepsTargetName": "build-deps",
        "watchDepsTargetName": "watch-deps"
      }
    }
  ],
  "generators": {
    "@nx/next": {
      "application": {
        "style": "css",
        "linter": "none"
      }
    }
  }
}
