{
  "name": "roviq",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc -b tsconfig.json",
    "dev:gateway": "nx serve api-gateway",
    "dev:institute": "nx serve institute-service",
    "dev:admin": "nx dev admin-portal -- -p 4200",
    "dev:portal": "nx dev institute-portal -- -p 4300",
    "dev:docker": "docker compose -f compose.dev.yaml up --watch",
    "dev:docker:build": "docker compose -f compose.dev.yaml up --watch --build",
    "dev:docker:down": "docker compose -f compose.dev.yaml down",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "db:migrate": "bash -c 'cd libs/prisma-client && pnpx prisma migrate deploy'",
    "db:migrate:dev": "bash -c 'cd libs/prisma-client && pnpx prisma migrate dev'",
    "db:generate": "pnpx prisma generate --schema=libs/prisma-client/prisma/schema.prisma",
    "db:seed": "pnpx tsx scripts/seed.ts",
    "db:reset": "bash -c 'cd libs/prisma-client && pnpx prisma migrate reset --force'",
    "e2e": "nx run-many -t e2e",
    "e2e:gateway": "nx run api-gateway-e2e:e2e",
    "e2e:admin-portal": "nx run admin-portal-e2e:e2e",
    "e2e:institute-portal": "nx run institute-portal-e2e:e2e"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/js": "22.5.4",
    "@nx/nest": "22.5.4",
    "@nx/next": "22.5.4",
    "@nx/node": "22.5.4",
    "@nx/playwright": "^22.5.4",
    "@nx/vite": "^22.5.4",
    "@nx/vitest": "^22.5.4",
    "@nx/web": "22.5.4",
    "@playwright/test": "^1.58.2",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/graphql-type-json": "^0.3.5",
    "@types/node": "^22.0.0",
