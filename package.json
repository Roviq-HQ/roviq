{
  "name": "roviq",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0",
  "scripts": {
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc -b tsconfig.json",
    "dev:gateway": "nx serve api-gateway",
    "dev:admin": "nx dev admin-portal -- -p 4200 --hostname 0.0.0.0",
    "dev:portal": "nx dev institute-portal -- -p 4300 --hostname 0.0.0.0",
    "dev:notifications": "nx serve notification-service",
    "dev:docker": "docker compose -f docker/compose.dev.yaml up --watch",
    "dev:docker:build": "docker compose -f docker/compose.dev.yaml up --watch --build",
    "dev:docker:down": "docker compose -f docker/compose.dev.yaml down",
    "infra:up": "docker compose -f docker/compose.infra.yaml up -d",
    "infra:down": "docker compose -f docker/compose.infra.yaml down",
    "db:migrate": "nx run database:db:migrate",
    "db:generate": "nx run database:db:generate",
    "db:seed": "pnpx tsx scripts/seed.ts",
    "db:push": "nx run database:db:push",
    "db:reset": "pnpx tsx scripts/db-reset.ts",
    "db:studio": "nx run database:db:studio",
    "e2e": "nx run-many -t e2e",
    "e2e:gateway": "nx run api-gateway-e2e:e2e",
    "e2e:admin-portal": "nx run admin-portal-e2e:e2e",
    "e2e:institute-portal": "nx run institute-portal-e2e:e2e",
    "e2e:hurl": "docker compose -f docker/compose.e2e.yaml up -d --build --wait && docker compose -f docker/compose.e2e.yaml --profile hurl run --rm hurl-tests",
    "e2e:vitest": "docker compose -f docker/compose.e2e.yaml up -d --build --wait && docker compose -f docker/compose.e2e.yaml --profile vitest run --rm vitest-e2e",
    "e2e:all": "docker compose -f docker/compose.e2e.yaml up -d --build --wait && docker compose -f docker/compose.e2e.yaml --profile hurl run --rm hurl-tests && docker compose -f docker/compose.e2e.yaml --profile vitest run --rm vitest-e2e",
    "e2e:down": "docker compose -f docker/compose.e2e.yaml --profile hurl --profile vitest down -v --remove-orphans",
    "novu:setup": "scripts/novu-setup.sh",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
