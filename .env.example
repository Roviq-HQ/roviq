# Database — PostgreSQL connections
# DATABASE_URL — application runtime (roviq_app, non-superuser, RLS enforced)
DATABASE_URL=postgresql://roviq_app:roviq_app_dev@localhost:5432/roviq
# DATABASE_URL_ADMIN — admin operations (roviq_admin, policy-based RLS bypass)
DATABASE_URL_ADMIN=postgresql://roviq_admin:roviq_admin_dev@localhost:5432/roviq
# DATABASE_URL_MIGRATE — migrations only (roviq superuser, schema changes)
DATABASE_URL_MIGRATE=postgresql://roviq:roviq_dev@localhost:5432/roviq

# Test database — used by e2e tests (keeps dev DB untouched)
DATABASE_URL_TEST=postgresql://roviq_app:roviq_app_dev@localhost:5432/roviq_test
DATABASE_URL_TEST_MIGRATE=postgresql://roviq:roviq_dev@localhost:5432/roviq_test

# Redis
REDIS_URL=redis://localhost:6379

# NATS
NATS_URL=nats://localhost:4222

# JWT — access token signing key
JWT_SECRET=change-me
# JWT_REFRESH_SECRET — refresh token signing key (must differ from JWT_SECRET)
JWT_REFRESH_SECRET=change-me
# JWT_EXPIRATION — access token TTL (e.g. 15m)
JWT_EXPIRATION=15m
# JWT_REFRESH_EXPIRATION — refresh token TTL (e.g. 7d)
JWT_REFRESH_EXPIRATION=7d

# Allowed origins — used for CORS and WebAuthn (comma-separated)
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4300

# WebAuthn / Passkey
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Roviq

# MinIO / S3 — object storage for file uploads
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=roviq_minio
S3_SECRET_KEY=roviq_minio_dev
# S3_BUCKET_PREFIX — prefix for tenant-scoped buckets
S3_BUCKET_PREFIX=roviq-

# Temporal — workflow engine (host:port)
TEMPORAL_ADDRESS=localhost:7233

# Payment Gateway — Razorpay
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=placeholder
RAZORPAY_WEBHOOK_SECRET=placeholder

# Payment Gateway — Cashfree
CASHFREE_CLIENT_ID=placeholder
CASHFREE_CLIENT_SECRET=placeholder
CASHFREE_ENVIRONMENT=SANDBOX
CASHFREE_API_VERSION=2025-01-01

# Sentry — error tracking DSN (leave empty to disable)
SENTRY_DSN=

# App ports — each service runs on a distinct port
API_GATEWAY_PORT=3000
ADMIN_PORTAL_PORT=4200
INSTITUTE_PORTAL_PORT=4300

# OpenTelemetry — observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=api-gateway
OTEL_SERVICE_VERSION=0.0.0
LOG_LEVEL=info

# Grafana — embedded dashboard URL (admin-portal observability page)
NEXT_PUBLIC_GRAFANA_URL=http://localhost:3001

# API — public URL for browser-side requests (admin-portal health check, etc.)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Billing — return URL after payment gateway checkout (EE only)
BILLING_RETURN_URL=http://localhost:4200/billing/subscriptions

# Enterprise Edition — set to 'true' to enable EE features (billing, etc.)
# ROVIQ_EE=true

# API Gateway → Notification Service proxy
NOTIFICATION_SERVICE_URL=http://localhost:3002

# Notification Service — Novu Cloud
NOVU_SECRET_KEY=placeholder
NOVU_APPLICATION_IDENTIFIER=placeholder
NOTIFICATION_SERVICE_PORT=3002

# Frontend — Novu Inbox (public)
NEXT_PUBLIC_NOVU_APPLICATION_IDENTIFIER=placeholder

# Firebase — FCM push notifications (public, all values from Firebase console)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_VAPID_KEY — Web Push certificate key pair from Firebase console → Cloud Messaging
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Cloudflare Tunnel — expose local dev to internet (webhooks, mobile testing)
# Run: cloudflared tunnel login → cloudflared tunnel create roviq-dev → cloudflared tunnel route dns roviq-dev <subdomain>.<your-domain>
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_TUNNEL_HOSTNAME=
