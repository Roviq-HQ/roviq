{
  "name": "value-objects",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/value-objects/src",
  "projectType": "library",
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "libs/shared/value-objects"
      }
    },
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/value-objects",
        "main": "libs/shared/value-objects/src/index.ts",
        "tsConfig": "libs/shared/value-objects/tsconfig.lib.json",
        "assets": ["libs/shared/value-objects/*.md"]
      }
    }
  },
  "tags": []
}
