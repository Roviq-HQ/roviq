{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Audit Event Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "platform" },
            "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "reseller" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "institute" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(rate(roviq_audit_events_published_total[$__rate_interval])) by (scope)",
          "legendFormat": "{{scope}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(roviq_audit_events_consumed_total[$__rate_interval]))",
          "legendFormat": "consumed",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "Consumer Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 30 }
            ]
          },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "nats_consumer_num_pending{stream=\"AUDIT\", consumer=\"audit-log-writer\"}",
          "legendFormat": "pending messages",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "DLQ Depth",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(roviq_audit_events_dlq_total) or vector(0)",
          "legendFormat": "DLQ events",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(rate(roviq_audit_events_error_total[$__rate_interval])) by (error_type)",
          "legendFormat": "{{error_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Scope Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "platform" },
            "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "reseller" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "institute" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "single" },
        "pieType": "donut"
      },
      "targets": [
        {
          "expr": "sum(roviq_audit_events_published_total) by (scope)",
          "legendFormat": "{{scope}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Source Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "GATEWAY" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "CORE_SERVICE" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "single" },
        "pieType": "donut"
      },
      "targets": [
        {
          "expr": "sum(roviq_audit_events_published_total) by (source)",
          "legendFormat": "{{source}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Impersonation Volume",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "platform" },
            "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "reseller" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "institute" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#808080", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(rate(roviq_audit_impersonation_total[$__rate_interval])) by (scope)",
          "legendFormat": "{{scope}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Top Entity Types by Volume",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "topk(10, sum by (entity_type) (roviq_audit_events_published_total))",
          "legendFormat": "{{entity_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Bulk Operations",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(roviq_audit_events_published_total{entity_type=~\".+\"}) or vector(0)",
          "legendFormat": "Total events",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Partition Sizes",
      "description": "Query PostgreSQL directly:\nSELECT relname, pg_size_pretty(pg_total_relation_size(relname::regclass))\nFROM pg_class WHERE relname LIKE 'audit_logs_%' ORDER BY relname DESC;",
      "type": "text",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "options": {
        "mode": "markdown",
        "content": "### Partition Sizes\n\nRequires PostgreSQL datasource. Run manually:\n\n```sql\nSELECT relname,\n  pg_size_pretty(pg_total_relation_size(relname::regclass)) AS size,\n  reltuples::bigint AS row_estimate\nFROM pg_class\nWHERE relname LIKE 'audit_logs_%'\nORDER BY relname DESC;\n```"
      }
    },
    {
      "id": 11,
      "title": "Index Sizes",
      "description": "Query PostgreSQL directly for the 7 audit_logs indexes.",
      "type": "text",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "options": {
        "mode": "markdown",
        "content": "### Index Sizes\n\nRequires PostgreSQL datasource. Run manually:\n\n```sql\nSELECT indexrelname,\n  pg_size_pretty(pg_relation_size(indexrelid)) AS size\nFROM pg_stat_user_indexes\nWHERE relname LIKE 'audit_logs%'\nORDER BY pg_relation_size(indexrelid) DESC;\n```"
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["roviq", "audit", "observability"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Roviq — Audit Logging",
  "uid": "roviq-audit-logging",
  "version": 1
}
