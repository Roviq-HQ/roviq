{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@roviq/common-types": ["libs/shared/common-types/src/index.ts"],
      "@roviq/nats-jetstream": ["libs/backend/nats-jetstream/src/index.ts"],
      "@roviq/resilience": ["libs/backend/resilience/src/index.ts"],
      "@roviq/ui": ["libs/frontend/ui/src/index.ts"],
      "@roviq/ui/*": ["libs/frontend/ui/src/*"],
      "@roviq/graphql": ["libs/frontend/graphql/src/index.ts"],
      "@roviq/graphql/generated": ["libs/frontend/graphql/src/generated/graphql.ts"],
      "@roviq/auth": ["libs/frontend/auth/src/index.ts"],
      "@roviq/i18n": ["libs/frontend/i18n/src/index.ts"],
      "@roviq/redis": ["libs/backend/redis/src/index.ts"],
      "@roviq/casl": ["libs/backend/casl/src/index.ts"],
      "@roviq/telemetry": ["libs/backend/telemetry/src/index.ts"],
      "@roviq/audit": ["libs/backend/audit/src/index.ts"],
      "@roviq/ee-gateway": ["ee/apps/api-gateway/src/index.ts"],
      "@roviq/ee-payments": ["ee/libs/backend/payments/src/index.ts"],
      "@roviq/notifications": ["libs/backend/notifications/src/index.ts"],
      "@roviq/nestjs-graphql": ["libs/backend/nestjs-graphql/src/index.ts"],
      "@roviq/domain": ["libs/shared/domain/src/index.ts"],
      "@roviq/database": ["libs/database/src/index.ts"],
      "@roviq/ee-billing-types": ["ee/libs/shared/billing-types/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
